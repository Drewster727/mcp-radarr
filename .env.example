# Radarr MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.

# Required: Base URL of your Radarr instance
RADARR_URL=http://localhost:7878

# Required: API key from Radarr → Settings → General → Security
RADARR_API_KEY=

# Required: Root folder path Radarr uses for movies (must match a path configured in Radarr)
RADARR_ROOT_FOLDER_PATH=/movies

# Optional: Quality profile name to assign when adding new movies (default: Any)
RADARR_DEFAULT_QUALITY_PROFILE=Any

# Optional: Set to true to enable update_movie and delete_movie tools (default: false)
RADARR_ALLOW_MUTATIONS=false
